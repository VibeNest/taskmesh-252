generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum NotificationType {
  WORKSPACE_INVITATION
  WORKSPACE_MEMBER_JOINED
  TASK_ASSIGNED
  TASK_MENTION
  COMMENT_MENTION
  TASK_UPDATED
  BOARD_CREATED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum TaskEstimate {
  XS
  S
  M
  L
  XL
}

enum ActivityAction {
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  MEMBER_JOINED
  MEMBER_REMOVED
  ROLE_CHANGED
  INVITATION_SENT
  BOARD_CREATED
  BOARD_UPDATED
  BOARD_DELETED
  COLUMN_CREATED
  COLUMN_UPDATED
  COLUMN_DELETED
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED
  TASK_DELETED
  TASK_ASSIGNED
  COMMENT_ADDED
  COMMENT_DELETED
  LABEL_CREATED
  LABEL_DELETED
  SPRINT_CREATED
  SPRINT_STARTED
  SPRINT_COMPLETED
  EXPORT_REQUESTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  jobTitle      String?
  department    String?
  phone         String?
  timezone      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
 ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  memberships WorkspaceMember[]
  invitationsReceived Invitation[] @relation("InvitationRecipient")
  invitationsSent Invitation[] @relation("InvitationSender")
  notifications Notification[]
  activityLogs ActivityLog[]
  comments Comment[]
  tasksAssigned Task[] @relation("TaskAssignee")
  tasksCreated Task[] @relation("TaskCreator")
  tasksUpdated Task[] @relation("TaskUpdater")
  subtasksAssigned Subtask[] @relation("SubtaskAssignee")
  attachmentsUploaded Attachment[] @relation("AttachmentUploader")
  taskViewsCreated TaskView[] @relation("TaskViewCreator")
  loginHistory LoginHistory[]
  userSessions UserSession[]
  fileAttachments FileAttachment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  plan        String   @default("free")
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
 owner User @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  invitations Invitation[]
  boards Board[]
  activityLogs ActivityLog[]
  labels Label[]
  taskViews TaskView[]
  sprints Sprint[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        Role             @default(MEMBER)
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  senderId String?
  sender User? @relation("InvitationSender", fields: [senderId], references: [id])

  recipientId String?
  recipient User? @relation("InvitationRecipient", fields: [recipientId], references: [id])

  @@map("invitations")
}

model Board {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  columns Column[]
  activityLogs ActivityLog[]

  @@map("boards")
}

model Column {
  id        String   @id @default(cuid())
  name      String
  position  Int      @default(0)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@map("columns")
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  position    Int         @default(0)
  priority    String?
  status      TaskStatus  @default(TODO)
  estimate    TaskEstimate?
  storyPoints Int?
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  columnId String
  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee User? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  creatorId String
  creator User @relation("TaskCreator", fields: [creatorId], references: [id])

  updaterId String?
  updater User? @relation("TaskUpdater", fields: [updaterId], references: [id])

  comments Comment[]
  activityLogs ActivityLog[]
  labels TaskLabel[]
  subtasks Subtask[]
  attachments Attachment[]
  sprintId String?
  sprint Sprint? @relation(fields: [sprintId], references: [id])

  @@index([columnId])
  @@index([assigneeId])
  @@index([sprintId])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  mentions String[] @default([])

  activityLogs ActivityLog[]

  @@map("comments")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id          String        @id @default(cuid())
  action      ActivityAction
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime      @default(now())

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String?
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  boardId String?
  board Board? @relation(fields: [boardId], references: [id], onDelete: Cascade)

  commentId String?
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model Label {
  id          String   @id @default(cuid())
  name        String
  color       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks TaskLabel[]

  @@unique([name, workspaceId])
  @@index([workspaceId])
  @@map("labels")
}

model TaskLabel {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  taskId String
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  labelId String
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@map("task_labels")
}

model Subtask {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskId String
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee User? @relation("SubtaskAssignee", fields: [assigneeId], references: [id])

  @@index([taskId])
  @@map("subtasks")
}

model Attachment {
  id          String   @id @default(cuid())
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  createdAt   DateTime @default(now())

  taskId String
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy User @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("attachments")
}

model TaskView {
  id          String   @id @default(cuid())
  name        String
  filters     Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdById String
  createdBy User @relation("TaskViewCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@map("task_views")
}

model Sprint {
  id          String        @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus  @default(PLANNED)
  goal        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([workspaceId])
  @@map("sprints")
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FeatureFlagName {
  AI_TASK_ASSISTANT
  AI_SPRINT_PLANNER
  ADVANCED_ANALYTICS
  BETA_BOARD_VIEW
  EXPORT_CSV
  GLOBAL_SEARCH
  IMMUTABLE_AUDIT_LOGS
  NATIVE_AUTH
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  email     String?
  ipAddress String?
  userAgent String?
  device    String?
  location  String?
  success   Boolean  @default(true)
  failReason String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  sessionToken String  @unique
  ipAddress   String?
  userAgent   String?
  device      String?
  isActive    Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@map("user_sessions")
}

model ImmutableAuditLog {
  id           String   @id @default(cuid())
  action       String
  entityType   String
  entityId     String
  userId       String
  workspaceId  String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  hash         String   @unique
  previousHash String
  timestamp    DateTime @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("immutable_audit_logs")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  name        FeatureFlagName @unique
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  rules       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model FileAttachment {
  id          String   @id @default(cuid())
  fileName    String
  fileKey     String
  fileSize    Int
  mimeType    String
  entityType  String
  entityId    String
  uploadedById String
  workspaceId String?
  createdAt   DateTime @default(now())

  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([workspaceId])
  @@map("file_attachments")
}
